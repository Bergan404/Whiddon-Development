---
import "../styles/global.css";

interface Props {
  title?: string;
}

const { title = "Whiddon Development" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <script>
      import { initResizeCover } from "../scripts/fit-viewport.js";
      // import { initTicker } from "../scripts/scroll.js";

      initResizeCover();
      // initTicker();
    </script>

    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="A higher standard for residential living in South Florida."
    />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
